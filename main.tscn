[sub_resource type="Shader" id="Shader_starfield"]
code = "
shader_type sky;

uniform float star_brightness : hint_range(0.0, 3.0) = 1.5;
uniform float twinkle_speed : hint_range(0.0, 5.0) = 1.5;

float hash21(vec2 p) {
    p = fract(p * vec2(234.34, 435.345));
    p += dot(p, p + 34.23);
    return fract(p.x * p.y);
}

float hash31(vec3 p) {
    p = fract(p * vec3(443.897, 441.423, 437.195));
    p += dot(p, p.yzx + 19.19);
    return fract((p.x + p.y) * p.z);
}

void sky() {
    vec3 dir = normalize(EYEDIR);

    // Pure black background
    vec3 bg_color = vec3(0.0, 0.0, 0.0);

    // Convert direction to spherical for better star distribution
    float theta = atan(dir.z, dir.x);
    float phi = acos(dir.y);

    float star = 0.0;

    // Multiple layers of stars at different scales
    for(int layer = 0; layer < 3; layer++) {
        float scale = 80.0 + float(layer) * 40.0;
        vec2 uv = vec2(theta, phi) * scale;
        vec2 gv = fract(uv) - 0.5;
        vec2 id = floor(uv);

        // Random offset within cell
        vec2 offset = vec2(hash21(id + float(layer) * 100.0), hash21(id.yx + float(layer) * 100.0)) - 0.5;
        offset *= 0.8;

        float d = length(gv - offset);

        // Star threshold based on hash
        float threshold = hash21(id * 1.23 + float(layer) * 50.0);
        if(threshold > 0.97) {
            float brightness = hash21(id * 2.34 + float(layer) * 75.0);
            float twinkle = sin(TIME * twinkle_speed * (hash21(id * 3.45) + 0.5) + hash21(id * 4.56) * 6.28) * 0.3 + 0.7;
            float size = 0.03 + hash21(id * 5.67) * 0.04;
            star += smoothstep(size, 0.0, d) * brightness * twinkle * star_brightness;
        }
    }

    COLOR = bg_color + vec3(star);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_sky"]
shader = SubResource("Shader_starfield")
shader_parameter/star_brightness = 0.0
shader_parameter/twinkle_speed = 1.5

[sub_resource type="Sky" id="Sky_space"]
sky_material = SubResource("ShaderMaterial_sky")

