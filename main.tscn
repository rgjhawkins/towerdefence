[ext_resource type="PackedScene" path="res://collector_ship.tscn" id="6_collector"]
[ext_resource type="PackedScene" path="res://hud.tscn" id="5_hud"]

[sub_resource type="Shader" id="Shader_starfield"]
code = "
shader_type sky;

uniform float star_density : hint_range(0.0, 0.1) = 0.02;
uniform float star_brightness : hint_range(0.0, 2.0) = 1.0;
uniform float twinkle_speed : hint_range(0.0, 5.0) = 1.5;
uniform vec3 nebula_color1 : source_color = vec3(0.1, 0.0, 0.2);
uniform vec3 nebula_color2 : source_color = vec3(0.0, 0.05, 0.15);

float hash(vec3 p) {
    p = fract(p * 0.3183099 + 0.1);
    p *= 17.0;
    return fract(p.x * p.y * p.z * (p.x + p.y + p.z));
}

float noise(vec3 p) {
    vec3 i = floor(p);
    vec3 f = fract(p);
    f = f * f * (3.0 - 2.0 * f);
    return mix(
        mix(mix(hash(i + vec3(0,0,0)), hash(i + vec3(1,0,0)), f.x),
            mix(hash(i + vec3(0,1,0)), hash(i + vec3(1,1,0)), f.x), f.y),
        mix(mix(hash(i + vec3(0,0,1)), hash(i + vec3(1,0,1)), f.x),
            mix(hash(i + vec3(0,1,1)), hash(i + vec3(1,1,1)), f.x), f.y), f.z);
}

void sky() {
    vec3 dir = EYEDIR;
    float nebula = noise(dir * 2.0) * 0.5 + 0.5;
    vec3 bg_color = mix(nebula_color1, nebula_color2, nebula);
    bg_color += noise(dir * 4.0) * 0.05;

    vec3 star_pos = dir * 500.0;
    vec3 star_cell = floor(star_pos);
    float star = 0.0;

    for(int x = -1; x <= 1; x++) {
        for(int y = -1; y <= 1; y++) {
            for(int z = -1; z <= 1; z++) {
                vec3 cell = star_cell + vec3(float(x), float(y), float(z));
                vec3 cell_center = cell + hash(cell) * 0.8 + 0.1;
                float dist = length(star_pos - cell_center);
                if(hash(cell + 0.5) < star_density) {
                    float brightness = hash(cell + 1.0);
                    float twinkle = sin(TIME * twinkle_speed * (hash(cell + 2.0) * 2.0 + 0.5) + hash(cell + 3.0) * 6.28) * 0.3 + 0.7;
                    star += smoothstep(0.5, 0.0, dist) * brightness * twinkle * star_brightness;
                }
            }
        }
    }
    COLOR = bg_color + vec3(star);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_sky"]
shader = SubResource("Shader_starfield")
shader_parameter/star_density = 0.02
shader_parameter/star_brightness = 1.2
shader_parameter/twinkle_speed = 1.5
shader_parameter/nebula_color1 = Vector3(0.1, 0.0, 0.2)
shader_parameter/nebula_color2 = Vector3(0.0, 0.05, 0.15)

[sub_resource type="Sky" id="Sky_space"]
sky_material = SubResource("ShaderMaterial_sky")

[sub_resource type="Environment" id="Environment_space"]
