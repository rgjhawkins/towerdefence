[sub_resource type="QuadMesh" id="QuadMesh_star_far"]
material = SubResource("StarMaterial_far")
size = Vector2(0.04, 0.04)

[sub_resource type="GDScript" id="GDScript_starfield"]
script/source = "extends Node3D

@export var star_count_close: int = 50
@export var star_count_mid: int = 100
@export var star_count_far: int = 200

@export var speed_close: float = 15.0
@export var speed_mid: float = 6.0
@export var speed_far: float = 2.0

@export var spawn_top: float = 50.0
@export var despawn_bottom: float = -50.0
@export var spread_x: float = 60.0

var close_stars: Array[MeshInstance3D] = []
var mid_stars: Array[MeshInstance3D] = []
var far_stars: Array[MeshInstance3D] = []

@onready var mesh_close: QuadMesh = $MeshClose.mesh
@onready var mesh_mid: QuadMesh = $MeshMid.mesh
@onready var mesh_far: QuadMesh = $MeshFar.mesh

func _ready() -> void:
	_spawn_layer(close_stars, star_count_close, mesh_close, -5.0, -2.0)
	_spawn_layer(mid_stars, star_count_mid, mesh_mid, -15.0, -5.0)
	_spawn_layer(far_stars, star_count_far, mesh_far, -40.0, -15.0)

func _spawn_layer(layer: Array[MeshInstance3D], count: int, mesh: Mesh, y_min: float, y_max: float) -> void:
	for i in count:
		var star := MeshInstance3D.new()
		star.mesh = mesh
		star.position = Vector3(
			randf_range(-spread_x, spread_x),
			randf_range(y_min, y_max),
			randf_range(despawn_bottom, spawn_top)
		)
		add_child(star)
		layer.append(star)

func _process(delta: float) -> void:
	_move_layer(close_stars, speed_close, delta)
	_move_layer(mid_stars, speed_mid, delta)
	_move_layer(far_stars, speed_far, delta)

func _move_layer(layer: Array[MeshInstance3D], speed: float, delta: float) -> void:
	for star in layer:
		star.position.z -= speed * delta
		if star.position.z < despawn_bottom:
			star.position.z = spawn_top
			star.position.x = randf_range(-spread_x, spread_x)
"

[node name="Main" type="Node3D"]

